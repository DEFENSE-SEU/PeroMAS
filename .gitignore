*.csv
*.parquet
*.feather

# -----------------------------------------------------------------------------
# 排除大型目录 - Exclude Large Directories
# -----------------------------------------------------------------------------
# 整个 dataset 目录（大型数据文件，不需要上传）
dataset/

# src/test 目录（测试文件，不需要上传）
src/test/

# CSLLM 相关（大型模型/数据）
mcp/design_agent/CSLLM/

# Mattergen 相关（大型模型/数据）
mcp/design_agent/mattergen/

# train_on_service 目录（训练相关，不需要上传）
train_on_service/

# -----------------------------------------------------------------------------
# Output / Cache Directories
# -----------------------------------------------------------------------------
experiment/workflow/experiment_output/
experiment/workflow/papers/
experiment/single_point/*/experiment_output/
experiment/single_point/*/papers/
src/test/papers/
src/test/output/
mcp/*/test_output/
mcp/fab_agent/Perovskite_PI_Multi/models/
evaluate_cache/
test_output/
output/
logs/
*.log

# -----------------------------------------------------------------------------
# MCP Server Data
# -----------------------------------------------------------------------------
mcp/data_agent/arxiv-mcp-server/
mcp/data_agent/Sci-Hub-MCP-Server/

# -----------------------------------------------------------------------------
# Temporary Files
# -----------------------------------------------------------------------------
*.tmp
*.temp
*.bak
.DS_Store
Thumbs.db

# -----------------------------------------------------------------------------
