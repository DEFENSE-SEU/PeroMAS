# =============================================================================
# PSC_Agents .gitignore
# =============================================================================

# -----------------------------------------------------------------------------
# Python
# -----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# -----------------------------------------------------------------------------
# Virtual Environments
# -----------------------------------------------------------------------------
.env
.venv/
env/
venv/
ENV/

# -----------------------------------------------------------------------------
# IDE / Editor
# -----------------------------------------------------------------------------
.idea/
.vscode/
*.swp
*.swo
*~
.project
.pydevproject
.settings/

# -----------------------------------------------------------------------------
# Jupyter Notebook
# -----------------------------------------------------------------------------
.ipynb_checkpoints/
*.ipynb_checkpoints

# -----------------------------------------------------------------------------
# Testing
# -----------------------------------------------------------------------------
.pytest_cache/
.coverage
htmlcov/
.tox/
.nox/

# -----------------------------------------------------------------------------
# Model Files (Large)
# -----------------------------------------------------------------------------
*.pkl
*.joblib
*.h5
*.hdf5
*.pt
*.pth
*.ckpt
*.safetensors

# -----------------------------------------------------------------------------
# Data Files (Large)
# -----------------------------------------------------------------------------
*.csv
*.parquet
*.feather

# -----------------------------------------------------------------------------
# Exclude Large Directories
# -----------------------------------------------------------------------------
# dataset directory (large data files)
dataset/

# src/test directory (test files)
src/test/

# experiment directory (experimental files)
experiment/

# CSLLM artifacts (large models/data)
mcp/design_agent/CSLLM/

# Mattergen artifacts (large models/data)
mcp/design_agent/mattergen/

# train_on_service directory (training artifacts)
train_on_service/

# -----------------------------------------------------------------------------
# Output / Cache Directories
# -----------------------------------------------------------------------------
experiment/workflow/experiment_output/
experiment/workflow/papers/
experiment/single_point/*/experiment_output/
experiment/single_point/*/papers/
src/test/papers/
src/test/output/
mcp/*/test_output/
mcp/fab_agent/Perovskite_PI_Multi/models/
evaluate_cache/
test_output/
output/
logs/
*.log

# -----------------------------------------------------------------------------
# MCP Server Data
# -----------------------------------------------------------------------------
mcp/data_agent/arxiv-mcp-server/
mcp/data_agent/Sci-Hub-MCP-Server/

# -----------------------------------------------------------------------------
# Temporary Files
# -----------------------------------------------------------------------------
*.tmp
*.temp
*.bak
.DS_Store
Thumbs.db

# -----------------------------------------------------------------------------
# Secrets / Credentials
# -----------------------------------------------------------------------------
*.pem
*.key
secrets/
credentials/
